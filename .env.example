# Salutis Backend - Environment Variables Template
# Copy this file to .env in the project root and fill with your local values
# IMPORTANT: .env is listed in .gitignore and should NEVER be committed to Git
# WARNING: Never commit real credentials, API keys, or secrets

# ===== DATABASE CONFIGURATION =====
# PostgreSQL connection URL
# Format: jdbc:postgresql://host:port/database
DB_URL=jdbc:postgresql://localhost:5432/salutis_dev

# Database username (default: postgres)
DB_USER=postgres

# Database password - use your actual PostgreSQL password here
DB_PASS=root

# ===== JWT AUTHENTICATION =====
# Secret key for signing JWT tokens
# Generate with: openssl rand -base64 32
# Minimum 32 characters required!
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters

# Token expiration time in milliseconds (default: 24 hours = 86400000)
JWT_EXPIRATION=86400000

# ===== APPLICATION SETTINGS =====
# Application name (used in logs and API docs)
APP_NAME=Salutis

# Server port (default: 8080)
PORT=8080

# Active Spring profiles: dev, prod
# dev   = local development with debug logging and Swagger enabled
# prod  = production with minimal logging and no Swagger
SPRING_PROFILES_ACTIVE=dev

# ===== LOGGING CONFIGURATION =====
# Log level: TRACE, DEBUG, INFO, WARN, ERROR
# dev = DEBUG, prod = WARN
LOG_LEVEL=INFO

# ===== DATABASE SCHEMA =====
# Hibernate DDL Auto strategy
# create-drop = drop and recreate schema on startup (dev only!)
# update     = update schema based on entities (development)
# validate   = only validate schema exists (production)
DDL_AUTO=update

# Show SQL queries in console (true/false)
SHOW_SQL=false
